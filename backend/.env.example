# ChainLogistics Backend Configuration
# Environment profile (development|production|test)
CHAINLOGISTICS_ENV=development

# Database
DATABASE_URL=postgres://chainlogistics:password@localhost/chainlogistics

# Server
HOST=0.0.0.0
PORT=3001

# TLS/SSL Configuration
TLS_ENABLED=false
TLS_CERT_PATH=/path/to/cert.pem
TLS_KEY_PATH=/path/to/key.pem

# Security
ENFORCE_HTTPS=true
HSTS_MAX_AGE=31536000
ALLOWED_ORIGINS=https://localhost:3000,https://app.chainlogistics.com

# Redis
REDIS_URL=redis://localhost:6379

# Required secrets
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef
JWT_SECRET=replace_with_minimum_16_character_secret

# Logging
RUST_LOG=info
LOG_FORMAT=json

# Optional nested overrides (config as code)
# CHAINLOGISTICS__SERVER__PORT=3001
# CHAINLOGISTICS__SECURITY__ENFORCE_HTTPS=true
