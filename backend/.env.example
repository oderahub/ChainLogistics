# ChainLogistics Backend Configuration

# Database
DATABASE_URL=postgres://chainlogistics:password@localhost/chainlogistics

# Server
HOST=0.0.0.0
PORT=3001

# TLS/SSL Configuration
TLS_ENABLED=false
TLS_CERT_PATH=/path/to/cert.pem
TLS_KEY_PATH=/path/to/key.pem

# Security
ENFORCE_HTTPS=true
HSTS_MAX_AGE=31536000
ALLOWED_ORIGINS=https://localhost:3000,https://app.chainlogistics.com,https://*.chainlogistics.com

# Redis
REDIS_URL=redis://localhost:6379

# Logging
RUST_LOG=info
