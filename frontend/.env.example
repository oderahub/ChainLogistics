# Frontend environment variables for local development
# Copy to .env.local and adjust values.

# Required for contract interactions
NEXT_PUBLIC_CONTRACT_ID=YOUR_SOROBAN_CONTRACT_ID
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_RPC_URL=https://soroban-testnet.stellar.org

# Optional app/runtime configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_MONITORING_ENDPOINT=
NEXT_PUBLIC_USE_MOCK_DATA=false
NEXT_PUBLIC_E2E_MOCKS=false

# Optional multi-chain configuration
NEXT_PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_STELLAR_CONTRACT_ID=

NEXT_PUBLIC_ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/
NEXT_PUBLIC_ETH_CONTRACT_ID=

NEXT_PUBLIC_POLYGON_RPC_URL=https://polygon-rpc.com
NEXT_PUBLIC_POLYGON_CONTRACT_ID=

NEXT_PUBLIC_HYPERLEDGER_RPC_URL=
NEXT_PUBLIC_HYPERLEDGER_CONTRACT_ID=

NEXT_PUBLIC_CORDA_RPC_URL=
NEXT_PUBLIC_CORDA_CONTRACT_ID=

NEXT_PUBLIC_QUORUM_RPC_URL=
NEXT_PUBLIC_QUORUM_CONTRACT_ID=

# Playwright (optional override)
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
